{
  "$schema": "node_modules/wrangler/config-schema.json",
  "main": "cloudflare-worker.js",
  "name": "agcpos",
  "workers_dev": false,
  "compatibility_date": "2026-07-04",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "out",
    "binding": "ASSETS"
  }
  // Add a Cloudflare custom domain when ready:
  // "routes": [{ "pattern": "pos.example.com", "custom_domain": true }]
}
